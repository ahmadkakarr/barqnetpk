---
// Code fence for JavaScript (Astro frontmatter)
import "../styles/global.css";

const navItems = [
    { href: "/", text: "Home" },
    {
        href: "#",
        text: "Services",
        submenu: [
            {
                href: "/services/telecom-consulting",
                text: "Telecom Consulting",
            },
            { href: "/services/network-solutions", text: "Network Solutions" },
            { href: "/services/managed-it", text: "Managed IT Services" },
            { href: "/services/cloud-services", text: "Cloud Services" },
        ],
    },
    {
        href: "/about",
        text: "About Us",
    },
    {
        href: "#",
        text: "Resources",
        submenu: [
            { href: "/resources/case-studies", text: "Case Studies" },
            { href: "/resources/white-papers", text: "White Papers" },
            { href: "/resources/blog", text: "Blog" },
        ],
    },
    { href: "/contact", text: "Contact" },
];
---

<header class="bg-white shadow-md">
    <div class="container mx-auto flex justify-between items-center py-4 px-6">
        <div class="text-3xl font-bold text-primary">
            <a href="/" aria-label="BARQ TELCOM Home">
                <picture>
                    <source srcset="/images/logo/logo.webp" type="image/webp" />
                    <img
                        src="/images/logo/logo.webp"
                        alt="BARQ TELCOM Logo"
                        class="h-12 w-auto"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
                    />
                    <span class="hidden">
                        <span class="text-accent">B</span>ARQ <span
                            class="text-primary">TELECOM</span
                        >
                    </span>
                </picture>
            </a>
        </div>

        <nav
            class="hidden md:flex space-x-8 relative"
            aria-label="Main navigation"
        >
            {
                navItems.map((item) => (
                    <div class="group relative">
                        <a
                            href={item.href}
                            class="text-secondary hover:text-primary flex items-center gap-1 py-2"
                            aria-haspopup={!!item.submenu}
                            aria-expanded={item.submenu ? "false" : undefined}
                            aria-controls={
                                item.submenu
                                    ? `desktop-submenu-${item.text}`
                                    : undefined
                            }
                        >
                            {item.text}
                            {item.submenu && (
                                <svg
                                    class="w-4 h-4 transition-transform transform group-hover:rotate-180"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"
                                    />
                                </svg>
                            )}
                        </a>
                        {item.submenu && (
                            <div
                                id={`desktop-submenu-${item.text}`}
                                class="absolute top-full left-0 bg-white shadow-lg rounded-lg mt-2 py-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-in-out z-50"
                            >
                                {item.submenu.map((subItem) => (
                                    <a
                                        href={subItem.href}
                                        class="block px-4 py-2 text-secondary hover:bg-gray-100 hover:text-primary"
                                    >
                                        {subItem.text}
                                    </a>
                                ))}
                            </div>
                        )}
                    </div>
                ))
            }
        </nav>

        <div class="md:hidden flex items-center">
            <button
                type="button"
                class="mobile-menu-button p-2"
                aria-label="Toggle mobile menu"
                aria-expanded="false"
                aria-controls="mobile-menu-content"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16m-7 6h7"></path>
                </svg>
            </button>
        </div>
    </div>

    <div class="mobile-menu-backdrop fixed inset-0 bg-black/50 z-40 hidden">
    </div>

    <div
        id="mobile-menu-content"
        class="mobile-menu fixed top-0 right-0 h-full w-64 bg-white shadow-lg transform translate-x-full transition-transform duration-300 ease-in-out z-50"
    >
        <div class="p-4 border-b border-gray-200">
            <div class="flex justify-between items-center">
                <div class="text-xl font-bold text-primary">
                    <a href="/" aria-label="BARQ TELCOM Home">
                        <picture>
                            <source
                                srcset="/images/logo/logo.webp"
                                type="image/webp"
                            />
                            <img
                                src="/images/logo/logo.webp"
                                alt="BARQ TELECOM Logo"
                                class="h-8 w-auto"
                                onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
                            />
                            <span class="hidden">
                                <span class="text-accent">B</span>ARQ <span
                                    class="text-primary">TELECOM</span
                                >
                            </span>
                        </picture>
                    </a>
                </div>
                <button
                    type="button"
                    class="mobile-menu-close p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 focus:outline-none"
                    aria-label="Close menu"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <nav class="py-4" aria-label="Mobile navigation">
            {
                navItems.map((item) => (
                    <div class="relative">
                        <a
                            href={item.href}
                            class="py-3 px-4 text-secondary hover:bg-gray-100 hover:text-primary transition-colors flex items-center justify-between mobile-menu-link"
                            data-has-submenu={!!item.submenu}
                            aria-haspopup={!!item.submenu}
                            aria-expanded={item.submenu ? "false" : undefined}
                            aria-controls={
                                item.submenu
                                    ? `mobile-submenu-${item.text}`
                                    : undefined
                            }
                        >
                            {item.text}
                            {item.submenu && (
                                <svg
                                    class="w-4 h-4 transition-transform transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"
                                    />
                                </svg>
                            )}
                        </a>
                        {item.submenu && (
                            <div
                                id={`mobile-submenu-${item.text}`}
                                class="submenu pl-6 hidden"
                            >
                                {item.submenu.map((subItem) => (
                                    <a
                                        href={subItem.href}
                                        class="block py-2 px-4 text-secondary hover:bg-gray-100 hover:text-primary"
                                    >
                                        {subItem.text}
                                    </a>
                                ))}
                            </div>
                        )}
                    </div>
                ))
            }
        </nav>
    </div>
</header>

<script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
        const mobileMenuButton = document.querySelector(".mobile-menu-button");
        const mobileMenu = document.querySelector(".mobile-menu");
        const mobileMenuBackdrop = document.querySelector(
            ".mobile-menu-backdrop",
        );
        const mobileMenuCloseButton =
            document.querySelector(".mobile-menu-close");
        const mobileMenuLinks = document.querySelectorAll(".mobile-menu-link");

        let isMenuOpen = false;

        function toggleMobileMenu() {
            isMenuOpen = !isMenuOpen;
            mobileMenuButton?.setAttribute("aria-expanded", String(isMenuOpen));

            if (isMenuOpen) {
                mobileMenu?.classList.remove("translate-x-full");
                mobileMenuBackdrop?.classList.remove("hidden");
                document.body.classList.add("overflow-hidden");
            } else {
                mobileMenu?.classList.add("translate-x-full");
                mobileMenuBackdrop?.classList.add("hidden");
                document.body.classList.remove("overflow-hidden");

                mobileMenuLinks.forEach((linkElement) => {
                    if (linkElement.dataset.hasSubmenu === "true") {
                        const submenu = linkElement.nextElementSibling;
                        const arrow = linkElement.querySelector("svg");
                        submenu?.classList.add("hidden");
                        arrow?.classList.remove("rotate-180");
                        linkElement.setAttribute("aria-expanded", "false");
                    }
                });
            }
        }

        mobileMenuButton?.addEventListener("click", toggleMobileMenu);
        mobileMenuCloseButton?.addEventListener("click", toggleMobileMenu);
        mobileMenuBackdrop?.addEventListener("click", toggleMobileMenu);

        mobileMenuLinks.forEach((linkElement) => {
            if (linkElement.dataset.hasSubmenu === "true") {
                linkElement.addEventListener("click", (e) => {
                    e.preventDefault();
                    const submenu = linkElement.nextElementSibling;
                    const arrow = linkElement.querySelector("svg");
                    const isSubmenuOpen =
                        !submenu?.classList.contains("hidden");

                    submenu?.classList.toggle("hidden");
                    arrow?.classList.toggle("rotate-180");
                    linkElement.setAttribute(
                        "aria-expanded",
                        String(!isSubmenuOpen),
                    );
                });
            } else {
                linkElement.addEventListener("click", () => {
                    if (
                        linkElement.getAttribute("href") &&
                        linkElement.getAttribute("href") !== "#"
                    ) {
                        if (isMenuOpen) {
                            toggleMobileMenu();
                        }
                    }
                });
            }
        });
    });
</script>

<style is:global>
    :root {
        --primary-color: #2563eb;
        --accent-color: #3b82f6;
        --secondary-color: #4b5563;
        --gradient-start: #b2d8d8;
        --gradient-end: #ffffff;
    }

    header nav a,
    .mobile-menu nav a {
        font-family: "Brush Script MT", cursive;
    }

    header nav > div > div a:hover {
        background-color: var(--accent-color);
        color: white !important;
    }

    .mobile-menu nav a:hover {
        background-color: var(--accent-color);
        color: white !important;
    }

    header.bg-white {
        background: linear-gradient(
            90deg,
            var(--gradient-start),
            var(--gradient-end)
        );
    }

    .mobile-menu-backdrop {
        transition: opacity 0.3s ease-in-out;
    }
    .mobile-menu-backdrop:not(.hidden) {
        opacity: 1;
    }

    .submenu {
        transition:
            max-height 0.3s ease-in-out,
            opacity 0.3s ease-in-out;
        max-height: 0;
        overflow: hidden;
        opacity: 0;
    }
    .submenu:not(.hidden) {
        max-height: 500px;
        opacity: 1;
    }

    .rotate-180 {
        transform: rotate(180deg);
    }

    .mobile-menu-button,
    .mobile-menu-close {
        cursor: pointer;
    }
</style>
