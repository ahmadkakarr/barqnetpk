---
import "../styles/global.css";
---

<!-- Tailwind 4, alpine for interactivity -->
<header class="bg-white" x-data="{ mobileMenuOpen: false }">
    <nav
        class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8"
        aria-label="Global"
    >
        <!-- Logo -->
        <div class="flex lg:flex-1">
            <a href="#" class="-m-1.5 p-1.5">
                <span class="sr-only">Your Company</span>
                <img
                    class="h-8 w-auto"
                    src="https://tailwindui.com/plus-assets/img/logos/mark.svg?color=indigo&shade=600"
                    alt=""
                />
            </a>
        </div>

        <!-- Mobile menu button -->
        <div class="flex lg:hidden">
            <button
                @click="mobileMenuOpen = true"
                type="button"
                class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700"
            >
                <span class="sr-only">Open main menu</span>
                <svg
                    class="size-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
                </svg>
            </button>
        </div>

        <!-- Desktop navigation -->
        <div class="hidden lg:flex lg:gap-x-12">
            <!-- Product dropdown -->
            <div class="relative" x-data="{ productOpen: false }">
                <button
                    @click="productOpen = !productOpen"
                    @keydown.escape="productOpen = false"
                    @mouseenter="productOpen = true"
                    @mouseleave="productOpen = false"
                    type="button"
                    class="flex items-center gap-x-1 text-sm/6 font-semibold text-gray-900"
                    :aria-expanded="productOpen"
                >
                    Product
                    <svg
                        class="size-5 flex-none text-gray-400"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                            clip-rule="evenodd"></path>
                    </svg>
                </button>

                <div
                    x-show="productOpen"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 translate-y-1"
                    class="absolute top-full -left-8 z-10 mt-3 w-screen max-w-md overflow-hidden rounded-3xl bg-white ring-1 shadow-lg ring-gray-900/5"
                    @click.outside="productOpen = false"
                >
                    <!-- Dropdown content remains the same -->
                </div>
            </div>

            <!-- Other navigation items -->
            <a href="#" class="text-sm/6 font-semibold text-gray-900"
                >Features</a
            >
            <a href="#" class="text-sm/6 font-semibold text-gray-900"
                >Marketplace</a
            >

            <!-- Company dropdown -->
            <div class="relative" x-data="{ companyOpen: false }">
                <button
                    @click="companyOpen = !companyOpen"
                    @keydown.escape="companyOpen = false"
                    @mouseenter="companyOpen = true"
                    @mouseleave="companyOpen = false"
                    type="button"
                    class="flex items-center gap-x-1 text-sm/6 font-semibold text-gray-900"
                    :aria-expanded="companyOpen"
                >
                    Company
                    <svg
                        class="size-5 flex-none text-gray-400"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                            clip-rule="evenodd"></path>
                    </svg>
                </button>

                <div
                    x-show="companyOpen"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 translate-y-1"
                    class="absolute top-full -left-8 z-10 mt-3 w-96 rounded-3xl bg-white p-4 ring-1 shadow-lg ring-gray-900/5"
                    @click.outside="companyOpen = false"
                >
                    <!-- Dropdown content remains the same -->
                </div>
            </div>
        </div>

        <!-- Login button -->
        <div class="hidden lg:flex lg:flex-1 lg:justify-end">
            <a href="#" class="text-sm/6 font-semibold text-gray-900">
                Log in <span aria-hidden="true">&rarr;</span>
            </a>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div
        x-show="mobileMenuOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="lg:hidden fixed inset-0 z-10"
        role="dialog"
        aria-modal="true"
    >
        <!-- Background backdrop -->
        <div
            class="fixed inset-0 bg-gray-900/50"
            @click="mobileMenuOpen = false"
        >
        </div>

        <!-- Mobile menu panel -->
        <div
            class="fixed inset-y-0 right-0 z-10 flex w-full flex-col justify-between overflow-y-auto bg-white sm:max-w-sm sm:ring-1 sm:ring-gray-900/10"
        >
            <div class="p-6">
                <div class="flex items-center justify-between">
                    <a href="#" class="-m-1.5 p-1.5">
                        <span class="sr-only">Your Company</span>
                        <img
                            class="h-8 w-auto"
                            src="https://tailwindui.com/plus-assets/img/logos/mark.svg?color=indigo&shade=600"
                            alt=""
                        />
                    </a>
                    <button
                        @click="mobileMenuOpen = false"
                        type="button"
                        class="-m-2.5 rounded-md p-2.5 text-gray-700"
                    >
                        <span class="sr-only">Close menu</span>
                        <svg
                            class="size-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M6 18 18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <!-- Mobile menu content remains the same -->
            </div>

            <!-- Mobile menu footer -->
            <div
                class="sticky bottom-0 grid grid-cols-2 divide-x divide-gray-900/5 bg-gray-50 text-center"
            >
                <a
                    href="#"
                    class="p-3 text-base/7 font-semibold text-gray-900 hover:bg-gray-100"
                    >Watch demo</a
                >
                <a
                    href="#"
                    class="p-3 text-base/7 font-semibold text-gray-900 hover:bg-gray-100"
                    >Contact sales</a
                >
            </div>
        </div>
    </div>
</header>
